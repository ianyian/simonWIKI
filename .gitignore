# --- Secrets & credentials (never commit) ---
.env
.env.*
*.key
*.pem
*.pfx
*secret*
*credential*
*.token
# --- Dependencies / build ---
node_modules/
dist/
build/
__pycache__/
*.pyc
.venv/
venv/
# --- OS / editor noise ---
.DS_Store
Thumbs.db
.idea/
*.swp
# --- VS Code: ignore local settings but DO share the MCP config ---
.vscode/*
!.vscode/mcp.json
